# DO NOT commit a filled-in copy of this file.
# On the cluster, create the secret once:
#
#   kubectl create secret generic app-secrets \
#     --namespace colours-of-safety \
#     --from-literal=DB_USERNAME=postgres \
#     --from-literal=DB_PASSWORD=<strong-password> \
#     --from-literal=DB_NAME=colours_of_safety \
#     --from-literal=JWT_SECRET=<long-random-string> \
#     --from-literal=JWT_EXPIRES_IN=7d \
#     --from-literal=REVIEWER_EMAIL=reviewer@coloursofsafety.com \
#     --from-literal=REVIEWER_PASSWORD=<strong-password>
#
# Or apply this file after filling in the base64-encoded values:
#   echo -n 'myvalue' | base64
apiVersion: v1
kind: Secret
metadata:
  name: app-secrets
  namespace: colours-of-safety
type: Opaque
data:
  DB_USERNAME: <base64>
  DB_PASSWORD: <base64>
  DB_NAME: <base64>
  JWT_SECRET: <base64>
  JWT_EXPIRES_IN: <base64>
  REVIEWER_EMAIL: <base64>
  REVIEWER_PASSWORD: <base64>
