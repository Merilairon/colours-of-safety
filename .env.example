# Copy to .env and adjust as needed. docker compose reads this automatically.

# --- Database (PostGIS) ---
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=colours_of_safety

# --- Auth ---
# Use a long random string in production.
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# --- Seeded default accounts (created on first boot) ---
REVIEWER_EMAIL=reviewer@coloursofsafety.com
REVIEWER_PASSWORD=reviewer123

SUPER_ADMIN_EMAIL=superadmin@coloursofsafety.com
SUPER_ADMIN_PASSWORD=superadmin123

# --- Frontend ---
# Host port the app is served on (http://localhost:FRONTEND_PORT)
FRONTEND_PORT=8080
